---
const features = [
  {
    num: '01',
    title: 'E2E Encrypted',
    desc: 'AES-256-GCM. The server is a dumb relay — it never sees your code. The key lives in the URL fragment, never sent over the wire.',
  },
  {
    num: '02',
    title: 'Any Editor',
    desc: 'Shadow syncs at the filesystem level. VS Code, Vim, Neovim, Zed, JetBrains, Emacs — if it reads files, it works.',
  },
  {
    num: '03',
    title: 'Zero Setup',
    desc: 'One curl to install. Run shadow and the interactive wizard handles the rest. No accounts, no config, no extensions.',
  },
];
---

<section class="features">
  <div class="features-inner">
    <h2 class="section-heading reveal" data-shadow="Built for developers">Built for developers</h2>

    <div class="card-row">
      {features.map((f, i) => (
        <article class={`card reveal reveal-d${i + 2}`}>
          <div class="card-num-wrap">
            <span class="card-num">{f.num}</span>
          </div>
          <h3 class="card-title">{f.title}</h3>
          <p class="card-desc">{f.desc}</p>
          <div class="card-accent" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    margin-bottom: var(--gap);
  }

  .features-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .card-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border-dim);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-top: 2.5rem;
  }

  .card {
    background: var(--bg-surface);
    padding: 2rem 1.75rem;
    position: relative;
    transition: background 0.3s;
  }

  .card:hover {
    background: var(--bg-elevated);
  }

  /* Accent line at top of card on hover */
  .card-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .card:hover .card-accent {
    transform: scaleX(1);
  }

  .card-num-wrap {
    margin-bottom: 1.5rem;
  }

  .card-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--border);
    letter-spacing: -0.04em;
    line-height: 1;
    transition: color 0.3s;
  }

  .card:hover .card-num {
    color: var(--accent-dim);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.65rem;
  }

  .card-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .card-row {
      grid-template-columns: 1fr;
    }
  }
</style>
