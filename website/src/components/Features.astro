---
const features = [
  {
    title: 'E2E Encrypted',
    desc: 'AES-256-GCM. The server is a dumb relay that never sees your code. The encryption key lives in the URL fragment — never sent over the wire.',
  },
  {
    title: 'Any Editor',
    desc: 'Shadow syncs at the filesystem level. VS Code, Vim, Neovim, Zed, JetBrains, Emacs — if it reads files, it works.',
  },
  {
    title: 'Zero Setup',
    desc: 'One curl to install. Run shadow and the wizard handles the rest. No accounts, no config files, no extensions to hunt down.',
  },
];
---

<section class="features">
  <div class="features-inner">
    <h2 class="heading reveal">Built for developers</h2>

    <div class="feature-list">
      {features.map((f, i) => (
        <article class={`feature reveal r-d${i + 1}`}>
          <div class="feature-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="feature-body">
            <h3 class="feature-title">{f.title}</h3>
            <p class="feature-desc">{f.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    margin-bottom: var(--gap);
  }

  .features-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    margin-bottom: 3rem;
    text-align: center;
  }

  .feature-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
  }

  .feature {
    padding: 2.25rem 2rem;
    border-left: 1px solid var(--border);
    transition: background 0.3s;
  }

  .feature:first-child {
    border-left: none;
  }

  .feature:hover {
    background: var(--bg-warm);
  }

  .feature-num {
    font-family: var(--font-serif);
    font-size: 2rem;
    color: var(--border-strong);
    line-height: 1;
    margin-bottom: 1.5rem;
    font-style: italic;
    transition: color 0.3s;
  }

  .feature:hover .feature-num {
    color: var(--accent);
  }

  .feature-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin-bottom: 0.6rem;
  }

  .feature-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .feature-list {
      grid-template-columns: 1fr;
    }
    .feature {
      border-left: none;
      border-top: 1px solid var(--border);
    }
    .feature:first-child { border-top: none; }
  }
</style>
