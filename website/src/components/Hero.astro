---
import { installCmd, marketplaceUrl } from '../consts';
---

<section class="hero">
  <div class="section-shell hero-inner">
    <div class="hero-copy">
      <h1 class="hero-title reveal">
        Screensharing ≠<br />pair programming.
      </h1>

      <p class="hero-desc reveal r-d1">
      <span class="desc-muted">Most "pairing" is one person driving. The other is <em class="desc-highlight">stuck</em> in someone else’s setup.</span>
      <br />
        <span class="desc-bright">Shadow lets both of you edit live, in your own editor.</span>
      </p>

      <p class="editor-support reveal r-d1">
        VS Code · Neovim · Vim · JetBrains · Zed — keep your setup.
      </p>

      <div class="hero-actions reveal r-d2">
        <div class="hero-install">
          <span class="install-label">Install Shadow CLI</span>
          <div class="cmd-preview">
            <code>{installCmd}</code>
            <button
              type="button"
              class="cmd-copy-btn"
              data-cta
              data-cta-source="hero"
              data-cta-target="cli"
              data-cta-surface="website"
              data-copy-text={installCmd}
              data-copy-source="hero"
              data-copy-target="cli"
              data-copy-surface="website"
              aria-label="Copy Shadow CLI install command"
            >
              <span data-copy-label>Copy</span>
            </button>
          </div>
        </div>

        <a
          href={marketplaceUrl}
          class="secondary-button"
          target="_blank"
          rel="noopener noreferrer"
          data-cta
          data-cta-source="hero"
          data-cta-target="vscode_marketplace"
          data-cta-surface="website"
        >
          Prefer VS Code? Install the extension &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(8rem, 18vh, 16rem);
    padding-bottom: clamp(5rem, 12vh, 10rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .hero-desc {
    font-size: 1.25rem;
    line-height: 1.7;
    margin-top: 2rem;
    max-width: 44rem;
  }

  .desc-muted {
    color: var(--text-muted);
  }

  .desc-highlight {
    color: var(--text);
    font-style: italic;
  }

  .desc-bright {
    color: var(--text);
  }

  .editor-support {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    margin-top: 1rem;
  }

  .install-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.6rem;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 3.5rem;
  }

  .hero-install {
    width: 100%;
    max-width: 38rem;
  }

  .cmd-preview {
    display: flex;
    align-items: stretch;
    border-radius: 0.5rem;
    border: 1px solid var(--border-strong);
    background: var(--bg-elevated);
    overflow: hidden;
  }

  .cmd-preview code {
    flex: 1;
    padding: 0.85rem 1.15rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
  }

  .cmd-copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.4rem;
    background: var(--accent);
    color: var(--bg);
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.88rem;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  .cmd-copy-btn:hover {
    background: var(--accent-strong);
  }

  .hero-actions .secondary-button {
    border: none;
    padding: 0.5rem 0;
    min-height: auto;
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .hero-actions .secondary-button:hover {
    color: var(--text);
    background: transparent;
    transform: none;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 5.5rem;
      padding-bottom: 4rem;
    }

    .hero-title {
      font-size: clamp(2.2rem, 9vw, 2.8rem);
    }

    .hero-desc {
      font-size: 1.1rem;
    }

    .editor-support {
      font-size: 0.72rem;
    }

    .cmd-preview code {
      font-size: 0.72rem;
    }
  }
</style>
