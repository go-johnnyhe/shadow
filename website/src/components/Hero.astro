---
import { installCmd, marketplaceUrl } from '../consts';
---

<section class="hero">
  <div class="section-shell hero-inner">
    <div class="hero-copy">
      <span class="eyebrow-chip reveal">Real-time. Encrypted. Your editor.</span>

      <h1 class="hero-title reveal r-d1">
        Share once.<br />
        Pair in <em>your own editor.</em>
      </h1>

      <p class="hero-desc reveal r-d2">
        One command to share. End-to-end encrypted. No accounts. Your teammate uses whatever
        editor they already have.
      </p>

      <div class="hero-actions reveal r-d3">
        <div class="hero-install">
          <div class="cmd-preview">
            <code>{installCmd}</code>
            <button
              type="button"
              class="cmd-copy-btn"
              data-cta
              data-cta-source="hero"
              data-cta-target="cli"
              data-cta-surface="website"
              data-copy-text={installCmd}
              data-copy-source="hero"
              data-copy-target="cli"
              data-copy-surface="website"
              aria-label="Copy Shadow CLI install command"
            >
              <span data-copy-label>Copy</span>
            </button>
          </div>
        </div>

        <a
          href={marketplaceUrl}
          class="secondary-button"
          target="_blank"
          rel="noopener noreferrer"
          data-cta
          data-cta-source="hero"
          data-cta-target="vscode_marketplace"
          data-cta-surface="website"
        >
          or install the VS Code extension &rarr;
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(6.5rem, 15vw, 12rem);
    padding-bottom: clamp(4rem, 10vw, 8rem);
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 52rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 6.5vw, 5.5rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin: 1.5rem 0;
    color: var(--text);
  }

  .hero-title em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1.25rem;
    color: var(--text-secondary);
    max-width: 42rem;
    margin-bottom: 2.8rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .hero-install {
    width: 100%;
    max-width: 38rem;
  }

  .cmd-preview {
    display: flex;
    align-items: stretch;
    border-radius: 0.5rem;
    border: 1px solid var(--border-strong);
    background: var(--bg-elevated);
    overflow: hidden;
  }

  .cmd-preview code {
    flex: 1;
    padding: 0.85rem 1.15rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    display: flex;
    align-items: center;
  }

  .cmd-copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.4rem;
    background: var(--accent);
    color: var(--bg);
    border: none;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.88rem;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  .cmd-copy-btn:hover {
    background: var(--accent-strong);
  }

  .hero-actions .secondary-button {
    border: none;
    padding: 0.5rem 0;
    min-height: auto;
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .hero-actions .secondary-button:hover {
    color: var(--text);
    background: transparent;
    transform: none;
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 5.5rem;
    }

    .hero-title {
      margin-top: 1.25rem;
    }

    .cmd-preview code {
      font-size: 0.72rem;
    }
  }
</style>
