---
import { installCmd, marketplaceUrl } from '../consts';
---

<section class="hero">
  <div class="section-shell hero-inner">
    <div class="hero-copy">
      <span class="eyebrow-chip reveal">Real-time. Encrypted. Your editor.</span>
      <p class="hero-label reveal r-d1">Pair in your own tools. No screen share.</p>

      <h1 class="hero-title reveal r-d2">
        Share once.<br />
        Pair in <em>your own editor.</em>
      </h1>

      <p class="hero-desc reveal r-d3">
        One command to share. End-to-end encrypted. No accounts. Your teammate uses whatever
        editor they already have.
      </p>

      <div class="hero-actions reveal r-d4">
        <button
          type="button"
          class="primary-button"
          data-cta
          data-cta-source="hero"
          data-cta-target="cli"
          data-cta-surface="website"
          data-copy-text={installCmd}
          data-copy-source="hero"
          data-copy-target="cli"
          data-copy-surface="website"
          aria-label="Copy Shadow CLI install command"
        >
          <span data-copy-label>Copy install command</span>
        </button>

        <a
          href={marketplaceUrl}
          class="secondary-button"
          target="_blank"
          rel="noopener noreferrer"
          data-cta
          data-cta-source="hero"
          data-cta-target="vscode_marketplace"
          data-cta-surface="website"
        >
          Install VS Code extension
        </a>
      </div>

      <div class="hero-proof reveal r-d4">
        <article>
          <span>Use any editor</span>
          <p>Vim, VS Code, JetBrains, Zed — whatever your team already uses.</p>
        </article>
        <article>
          <span>Join command copied for you</span>
          <p>No manual URL work. Shadow handles the copy step.</p>
        </article>
        <article>
          <span>E2E key stays in the URL</span>
          <p>The relay never sees your code. The key lives in the URL fragment.</p>
        </article>
      </div>
    </div>

    <aside class="hero-panel reveal r-d3">
      <div class="panel-header">
        <span class="panel-eyebrow">How it works</span>
        <span class="panel-status">ready to share</span>
      </div>

      <div class="panel-body">
        <div class="panel-step">
          <span class="panel-num">01</span>
          <div>
            <h2>Start in the surface you like</h2>
            <p>Run `shadow start .` from the CLI or launch a session from the VS Code sidebar.</p>
          </div>
        </div>

        <div class="panel-step">
          <span class="panel-num">02</span>
          <div>
            <h2>Shadow copies it for you</h2>
            <p>The join command includes the E2E key, so it's long on purpose. Shadow handles the copy step.</p>
          </div>
        </div>

        <div class="panel-command">
          <span>share with your teammate</span>
          <code>shadow join 'https://shadow-session.trycloudflare.com#e2e-key'</code>
        </div>

        <div class="panel-step">
          <span class="panel-num">03</span>
          <div>
            <h2>Both sides edit live</h2>
            <p>Not a screen share. Not editor lock-in. Same project updating in real time.</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(5.5rem, 10vw, 8rem);
    padding-bottom: var(--gap);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(320px, 0.9fr);
    gap: 2.5rem;
    align-items: stretch;
  }

  .hero-label {
    margin: 1.35rem 0 0;
    font-size: 1.02rem;
    color: var(--text-secondary);
    max-width: 34rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.4rem, 7.5vw, 6.5rem);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.04em;
    margin: 1.7rem 0;
    color: var(--text);
  }

  .hero-title em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1.08rem;
    color: var(--text-secondary);
    max-width: 36rem;
    margin-bottom: 2.2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-bottom: 2.25rem;
  }

  .hero-proof {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .hero-proof article {
    border: 1px solid var(--border);
    background: var(--paper);
    backdrop-filter: blur(14px);
    border-radius: 0.75rem;
    padding: 1.1rem 1.1rem 1.2rem;
  }

  .hero-proof span {
    display: block;
    margin-bottom: 0.55rem;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text);
  }

  .hero-proof p {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .hero-panel {
    border-radius: 1rem;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text);
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.03);
  }

  .panel-header,
  .panel-command,
  .panel-step {
    display: flex;
    align-items: flex-start;
  }

  .panel-header {
    justify-content: space-between;
    padding: 1.2rem 1.3rem;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.73rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  .panel-status {
    color: var(--accent);
  }

  .panel-body {
    padding: 1.3rem;
  }

  .panel-step {
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .panel-step:last-child {
    border-bottom: none;
    padding-bottom: 0.2rem;
  }

  .panel-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .panel-step h2 {
    font-size: 1.08rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .panel-step p,
  .panel-command span {
    color: var(--text-secondary);
  }

  .panel-command {
    flex-direction: column;
    gap: 0.65rem;
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem;
    margin: 1rem 0;
    background: var(--paper);
  }

  .panel-command span {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .panel-command code {
    font-size: 0.78rem;
    line-height: 1.65;
    word-break: break-all;
    color: var(--text);
  }

  @media (max-width: 980px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-proof {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 4.7rem;
    }

    .hero-title {
      margin-top: 1.25rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .hero-actions > * {
      width: 100%;
    }
  }
</style>
