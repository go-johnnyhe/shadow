---
const installCmd = 'curl -sSf https://raw.githubusercontent.com/go-johnnyhe/shadow/main/install.sh | sh';
---

<section class="hero">
  <div class="hero-inner">
    <p class="hero-label reveal">Real-time collaboration for any editor</p>

    <h1 class="hero-title reveal r-d1">
      Like Google Docs,<br />
      but for your <em>codebase.</em>
    </h1>

    <p class="hero-desc reveal r-d2">
      End-to-end encrypted file sync that works with every editor.
      No accounts, no extensions, no config. Just code together.
    </p>

    <div class="hero-terminal reveal r-d3">
      <div class="term-chrome">
        <span class="term-title">Terminal</span>
      </div>
      <div class="term-body">
        <span class="term-prompt">$</span>
        <code class="term-cmd" id="hero-cmd">{installCmd}</code>
        <button class="term-copy" id="hero-copy" aria-label="Copy install command">
          <svg class="ico-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <svg class="ico-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    </div>

    <p class="hero-alt reveal r-d4">
      or&ensp;<code>go install github.com/go-johnnyhe/shadow@latest</code>
    </p>
  </div>
</section>

<script is:inline>
  document.getElementById('hero-copy')?.addEventListener('click', function () {
    var cmd = document.getElementById('hero-cmd')?.textContent || '';
    navigator.clipboard.writeText(cmd).then(function () {
      var btn = document.getElementById('hero-copy');
      if (!btn) return;
      btn.querySelector('.ico-copy').style.display = 'none';
      btn.querySelector('.ico-check').style.display = 'block';
      btn.classList.add('copied');
      if (typeof posthog !== 'undefined') posthog.capture('install_command_copied');
      setTimeout(function () {
        btn.querySelector('.ico-copy').style.display = 'block';
        btn.querySelector('.ico-check').style.display = 'none';
        btn.classList.remove('copied');
      }, 2000);
    });
  });
</script>

<style>
  .hero {
    padding-top: clamp(7rem, 16vh, 12rem);
    padding-bottom: var(--gap);
  }

  .hero-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    text-align: center;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(2.6rem, 7vw, 4.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.75rem;
    color: var(--text);
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 auto 3rem;
    line-height: 1.7;
  }

  /* ——— Terminal block — dark on light ——— */
  .hero-terminal {
    max-width: 540px;
    margin: 0 auto;
    background: var(--surface);
    border-radius: 10px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.06),
      0 4px 12px rgba(0,0,0,0.08),
      0 16px 40px rgba(0,0,0,0.12);
    transition: box-shadow 0.4s;
  }

  .hero-terminal:hover {
    box-shadow:
      0 1px 2px rgba(0,0,0,0.06),
      0 8px 20px rgba(0,0,0,0.1),
      0 24px 56px rgba(0,0,0,0.16);
  }

  .term-chrome {
    padding: 9px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .term-title {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.04em;
  }

  .term-body {
    display: flex;
    align-items: center;
    padding: 0.9rem 1.2rem;
    gap: 0.6rem;
  }

  .term-prompt {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 500;
    flex-shrink: 0;
    opacity: 0.8;
  }

  .term-cmd {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: rgba(255,255,255,0.85);
    white-space: nowrap;
    flex: 1;
    text-align: left;
    overflow-x: auto;
  }

  .term-copy {
    flex-shrink: 0;
    background: none;
    border: none;
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    border-radius: 4px;
    transition: color 0.2s;
  }
  .term-copy:hover { color: rgba(255,255,255,0.6); }
  .term-copy.copied { color: var(--accent); }

  .hero-alt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 1rem;
  }
  .hero-alt code {
    font-family: var(--font-mono);
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .hero { padding-top: 5rem; }
    .term-cmd { font-size: 0.68rem; }
  }
</style>
