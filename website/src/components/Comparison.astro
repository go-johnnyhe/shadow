---
const rows = [
  { label: 'Editor lock-in', shadow: 'None', liveshare: 'VS Code only', screen: 'None' },
  { label: 'Latency', shadow: 'Low (WebSocket)', liveshare: 'Low', screen: 'High' },
  { label: 'Both can edit', shadow: 'Yes', liveshare: 'Yes', screen: 'No' },
  { label: 'Setup required', shadow: 'Zero', liveshare: 'Extension install', screen: 'None' },
  { label: 'Encryption', shadow: 'E2E (AES-256)', liveshare: 'Microsoft servers', screen: 'Varies' },
];
---

<section class="comparison">
  <div class="comparison-inner">
    <h2 class="section-heading reveal" data-shadow="How is this different?">How is this different?</h2>

    <div class="table-frame reveal reveal-d1">
      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th class="col-label"></th>
              <th class="col-shadow">
                <span class="shadow-badge">Shadow</span>
              </th>
              <th class="col-other">Live Share</th>
              <th class="col-other">Screenshare</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((r, i) => (
              <tr>
                <td class="col-label">{r.label}</td>
                <td class="col-shadow">{r.shadow}</td>
                <td class="col-other">{r.liveshare}</td>
                <td class="col-other">{r.screen}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<style>
  .comparison {
    margin-bottom: var(--gap);
  }

  .comparison-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .table-frame {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-surface);
    margin-top: 2.5rem;
  }

  .table-scroll {
    overflow-x: auto;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    min-width: 600px;
  }

  thead tr {
    border-bottom: 1px solid var(--border);
  }

  th {
    text-align: left;
    padding: 1rem 1.4rem;
    font-weight: 500;
    color: var(--text-ghost);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  td {
    padding: 0.9rem 1.4rem;
    border-top: 1px solid var(--border-dim);
  }

  tr:first-child td { border-top: none; }

  tbody tr {
    transition: background 0.2s;
  }
  tbody tr:hover {
    background: var(--bg-elevated);
  }

  /* Label column */
  .col-label {
    color: var(--text-secondary);
    font-weight: 500;
    width: 25%;
    min-width: 140px;
  }

  /* Other columns */
  .col-other {
    color: var(--text-ghost);
    width: 20%;
  }

  /* Shadow column — highlighted */
  th.col-shadow {
    width: 30%;
  }

  .shadow-badge {
    display: inline-block;
    background: var(--accent-glow-mid);
    color: var(--accent);
    padding: 3px 10px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 1px solid rgba(34,197,94,0.15);
  }

  td.col-shadow {
    color: var(--accent);
    font-weight: 500;
    position: relative;
  }

  /* Subtle left-edge accent on the shadow column */
  td.col-shadow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 25%;
    bottom: 25%;
    width: 2px;
    background: var(--accent);
    border-radius: 1px;
    opacity: 0.4;
  }

  @media (max-width: 768px) {
    th, td {
      padding: 0.7rem 1rem;
      font-size: 0.75rem;
    }
  }
</style>
