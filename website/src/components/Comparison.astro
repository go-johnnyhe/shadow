---
const rows = [
  { label: 'Editor lock-in', shadow: 'None', liveshare: 'VS Code only', screen: 'None' },
  { label: 'Latency', shadow: 'Low (WebSocket)', liveshare: 'Low', screen: 'High' },
  { label: 'Both can edit', shadow: 'Yes', liveshare: 'Yes', screen: 'No' },
  { label: 'Setup required', shadow: 'Zero', liveshare: 'Extension install', screen: 'None' },
  { label: 'Encryption', shadow: 'E2E (AES-256)', liveshare: 'Microsoft servers', screen: 'Varies' },
];
---

<section class="comparison">
  <div class="comparison-inner">
    <h2 class="heading reveal">How is this different?</h2>

    <div class="table-wrap reveal r-d1">
      <table>
        <thead>
          <tr>
            <th class="col-label"></th>
            <th class="col-shadow">Shadow</th>
            <th class="col-other">Live Share</th>
            <th class="col-other">Screenshare</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="col-label">{r.label}</td>
              <td class="col-shadow">{r.shadow}</td>
              <td class="col-other">{r.liveshare}</td>
              <td class="col-other">{r.screen}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    margin-bottom: var(--gap);
  }

  .comparison-inner {
    max-width: var(--max-w);
    margin: 0 auto;
  }

  .heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .table-wrap {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
    min-width: 580px;
  }

  /* Scroll on small screens */
  .table-wrap {
    overflow-x: auto;
  }

  thead tr {
    border-bottom: 1px solid var(--border);
  }

  th {
    text-align: left;
    padding: 0.9rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  td {
    padding: 0.85rem 1.4rem;
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
  }

  tbody tr:first-child td { border-top: none; }

  tbody tr {
    transition: background 0.2s;
  }
  tbody tr:hover {
    background: var(--accent-soft);
  }

  .col-label {
    font-weight: 500;
    color: var(--text);
    width: 25%;
  }

  .col-other {
    width: 20%;
    color: var(--text-muted);
  }

  /* Shadow column — the star */
  th.col-shadow {
    color: var(--accent);
    font-weight: 600;
    width: 28%;
  }

  td.col-shadow {
    color: var(--accent);
    font-weight: 500;
    background: var(--accent-soft);
  }

  @media (max-width: 640px) {
    th, td {
      padding: 0.7rem 1rem;
      font-size: 0.8rem;
    }
  }
</style>
