---
const rows = [
{ label: 'Can you use your own editor?', shadow: 'Yes, any IDE!', liveshare: 'VS Code only', screen: 'You just watch' },
  { label: 'How do you share?', shadow: 'Click Start, paste the link', liveshare: 'Microsoft auth invite', screen: 'Meeting link + screen share app' },
  { label: 'Can both people type?', shadow: 'Yes', liveshare: 'Yes', screen: 'No' },
  { label: 'How fast does it feel?', shadow: 'Near-instant (file sync)', liveshare: 'Low latency', screen: 'Video-encoding lag' },
  { label: 'Who sees your code?', shadow: 'Nobody, E2E encrypted', liveshare: 'Relayed through Microsoft', screen: 'Depends on the provider' },
];
---

<section class="comparison">
  <div class="section-shell comparison-inner">
    <div class="comparison-copy reveal">
      <p class="section-kicker">The alternatives, honestly</p>
      <h2 class="section-title">You already know the workarounds. They all have a catch.</h2>
      <p class="section-lead">
        Screen share and one of you just watches. Live Share and one of you abandons their editor.
        Shadow syncs the actual files, so both people keep full control of their own setup.
      </p>
    </div>

    <div class="table-wrap reveal r-d1">
      <table>
        <thead>
          <tr>
            <th class="col-label"></th>
            <th class="col-shadow">Shadow</th>
            <th class="col-other">Live Share</th>
            <th class="col-other">Screenshare</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="col-label">{r.label}</td>
              <td class="col-shadow">{r.shadow}</td>
              <td class="col-other">{r.liveshare}</td>
              <td class="col-other">{r.screen}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .comparison {
    margin-bottom: clamp(6rem, 10vw, 10rem);
  }

  .comparison-copy {
    text-align: left;
    margin-bottom: 3rem;
    max-width: 48rem;
  }

  .table-wrap {
    overflow-x: auto;
    padding-bottom: 2rem;
  }

  table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 1rem;
    min-width: 760px;
  }

  th, td {
    padding: 1.5rem;
    text-align: left;
    vertical-align: top;
  }

  th {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
  }

  td {
    color: var(--text-secondary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  tbody tr:last-child td {
    border-bottom: none;
  }

  tbody tr {
    transition: background 0.2s ease;
  }

  tbody tr:hover td {
    background: rgba(255, 255, 255, 0.01);
  }

  .col-label {
    font-weight: 500;
    color: var(--text);
    width: 20%;
  }

  .col-other {
    width: 25%;
    color: var(--text-muted);
  }

  th.col-shadow {
    color: var(--accent);
    font-weight: 600;
    width: 30%;
  }

  td.col-shadow {
    color: var(--text);
    font-weight: 500;
    background: rgba(228, 146, 75, 0.03);
  }

  tbody tr:hover td.col-shadow {
    background: rgba(228, 146, 75, 0.05);
  }

  /* Round corners for the shadow column */
  th.col-shadow {
    border-top-left-radius: 0.75rem;
    border-top-right-radius: 0.75rem;
  }
  tbody tr:last-child td.col-shadow {
    border-bottom-left-radius: 0.75rem;
    border-bottom-right-radius: 0.75rem;
  }

  @media (max-width: 768px) {
    th, td {
      padding: 1.25rem 1rem;
      font-size: 0.9rem;
    }
  }
</style>
