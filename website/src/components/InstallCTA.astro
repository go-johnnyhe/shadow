---
import { dmgUrl, githubUrl } from '../consts';
---

<section class="cta" id="install">
  <div class="section-shell cta-inner reveal">
    <h2 class="section-title">You've scrolled this far.</h2>
    <p class="cta-lead">
      Next time someone says "let's pair," try Shadow.
      Download, click Start, send the link.
    </p>

    <div class="cta-actions reveal r-d1">
      <a
        href={dmgUrl}
        class="primary-button"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="download_mac"
        data-cta-surface="website"
      >
        Download for Mac
      </a>
      <a
        href={`${githubUrl}#readme`}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github_docs"
        data-cta-surface="website"
      >
        Read the docs on GitHub &rarr;
      </a>
    </div>

    <div class="cta-muted reveal r-d2">
      <span>Also available as a <a href={`${githubUrl}#install`} class="muted-link" target="_blank" rel="noopener noreferrer">CLI</a></span>
      <span class="sep">&middot;</span>
      <a
        href={githubUrl}
        class="muted-link"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github"
        data-cta-surface="website"
      >
        Star the repo &mdash; it helps others find Shadow
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    margin-bottom: clamp(10rem, 16vw, 16rem);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-lead {
    max-width: 36rem;
    margin: 1.25rem 0 2.5rem;
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-muted {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    justify-content: center;
  }

  .muted-link {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .muted-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .sep {
    color: var(--border-strong);
  }
</style>
