---
import { githubUrl } from '../consts';
---

<section class="cta">
  <div class="section-shell cta-inner reveal">
    <p class="section-kicker">Get started</p>
    <h2 class="section-title">Pair in under 60 seconds.</h2>
    <p class="cta-lead">
      That's it. No accounts, no auth flow, no new editor to learn.
    </p>

    <div class="quick-steps reveal r-d1">
      <div class="qs-step">
        <span class="qs-num">1</span>
        <div>
          <p class="qs-title">Install</p>
          <p class="qs-desc">Run the install script or grab the VS Code extension.</p>
        </div>
      </div>
      <div class="qs-step">
        <span class="qs-num">2</span>
        <div>
          <p class="qs-title">Start a session</p>
          <p class="qs-desc">Run <code>shadow start .</code> — the join command auto-copies to your clipboard.</p>
        </div>
      </div>
      <div class="qs-step">
        <span class="qs-num">3</span>
        <div>
          <p class="qs-title">Send it to a friend</p>
          <p class="qs-desc">They paste the command and start editing in their own editor, instantly.</p>
        </div>
      </div>
    </div>

    <div class="cta-links reveal r-d2">
      <a
        href={`${githubUrl}#readme`}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github_docs"
        data-cta-surface="website"
      >
        Read the docs on GitHub &rarr;
      </a>
      <a
        href={githubUrl}
        class="cta-star"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github"
        data-cta-surface="website"
      >
        Star the repo &middot; it helps others find Shadow
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    margin-bottom: calc(var(--gap) * 1.2);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-lead {
    max-width: 36rem;
    margin: 1.25rem 0 0;
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .quick-steps {
    display: flex;
    gap: 2.5rem;
    margin: 3.5rem 0;
    text-align: left;
    width: 100%;
    max-width: 48rem;
  }

  .qs-step {
    flex: 1;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .qs-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .qs-title {
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.3rem;
    font-size: 0.95rem;
  }

  .qs-desc {
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .qs-desc code {
    font-size: 0.82rem;
    padding: 0.15rem 0.4rem;
    background: var(--paper-strong);
    border-radius: 0.25rem;
    color: var(--text);
  }

  .cta-links {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cta-star {
    font-size: 0.88rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .cta-star:hover {
    color: var(--text-secondary);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .quick-steps {
      flex-direction: column;
      gap: 1.5rem;
    }
  }
</style>
