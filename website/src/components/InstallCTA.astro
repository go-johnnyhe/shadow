---
const installCmd = 'curl -sSf https://raw.githubusercontent.com/go-johnnyhe/shadow/main/install.sh | sh';
---

<section class="cta">
  <div class="cta-inner">
    <h2 class="heading reveal">Get started in seconds</h2>

    <div class="cta-terminal reveal r-d1">
      <div class="term-chrome">
        <span class="term-title">Terminal</span>
      </div>
      <div class="term-body">
        <span class="prompt">$</span>
        <code id="cta-cmd">{installCmd}</code>
        <button class="term-copy" id="cta-copy" aria-label="Copy">
          <svg class="ico-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <svg class="ico-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
    </div>

    <div class="steps reveal r-d2">
      <div class="step">
        <span class="step-n">1</span>
        <p class="step-text"><code>shadow start .</code> in your project</p>
      </div>
      <div class="step">
        <span class="step-n">2</span>
        <p class="step-text">Share the generated URL</p>
      </div>
      <div class="step">
        <span class="step-n">3</span>
        <p class="step-text"><code>shadow join '&lt;url&gt;'</code> — both edit live</p>
      </div>
    </div>

    <div class="reveal r-d3">
      <a
        href="https://github.com/go-johnnyhe/shadow"
        class="gh-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Star on GitHub
      </a>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('cta-copy')?.addEventListener('click', function () {
    var cmd = document.getElementById('cta-cmd')?.textContent || '';
    navigator.clipboard.writeText(cmd).then(function () {
      var btn = document.getElementById('cta-copy');
      if (!btn) return;
      btn.querySelector('.ico-copy').style.display = 'none';
      btn.querySelector('.ico-check').style.display = 'block';
      btn.classList.add('copied');
      if (typeof posthog !== 'undefined') posthog.capture('install_command_copied');
      setTimeout(function () {
        btn.querySelector('.ico-copy').style.display = 'block';
        btn.querySelector('.ico-check').style.display = 'none';
        btn.classList.remove('copied');
      }, 2000);
    });
  });
</script>

<style>
  .cta {
    margin-bottom: var(--gap);
  }

  .cta-inner {
    max-width: 580px;
    margin: 0 auto;
    text-align: center;
  }

  .heading {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 400;
    letter-spacing: -0.015em;
    margin-bottom: 2.5rem;
  }

  /* Terminal */
  .cta-terminal {
    background: var(--surface);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 2.5rem;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.06),
      0 4px 12px rgba(0,0,0,0.08),
      0 16px 40px rgba(0,0,0,0.12);
  }

  .term-chrome {
    padding: 9px 14px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .term-title {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: rgba(255,255,255,0.25);
  }

  .term-body {
    display: flex;
    align-items: center;
    padding: 0.9rem 1.2rem;
    gap: 0.6rem;
  }

  .prompt {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 500;
    flex-shrink: 0;
    opacity: 0.8;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: rgba(255,255,255,0.85);
    white-space: nowrap;
    flex: 1;
    text-align: left;
  }

  .term-copy {
    flex-shrink: 0;
    background: none;
    border: none;
    color: rgba(255,255,255,0.25);
    cursor: pointer;
    padding: 4px;
    display: flex;
    border-radius: 4px;
    transition: color 0.2s;
  }
  .term-copy:hover { color: rgba(255,255,255,0.6); }
  .term-copy.copied { color: var(--accent); }

  /* Steps */
  .steps {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    text-align: left;
  }

  .step {
    flex: 1;
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
  }

  .step-n {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .step-text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .step-text code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text);
    background: var(--bg-warm);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  /* GitHub link */
  .gh-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text);
    background: var(--text);
    color: var(--bg);
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .gh-link:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .steps { flex-direction: column; gap: 1rem; }
    code { font-size: 0.7rem; }
  }
</style>
