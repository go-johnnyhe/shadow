---
import { dmgUrl, githubUrl, installCmd } from '../consts';
---

<section class="cta" id="install">
  <div class="section-shell cta-inner reveal">
    <h2 class="section-title">You've scrolled this far.</h2>
    <p class="cta-lead">
      Next time someone says "let's pair," try Shadow.
      Download, click Start, send the link.
    </p>

    <div class="cta-actions reveal r-d1">
      <a
        href={dmgUrl}
        class="primary-button"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="download_mac"
        data-cta-surface="website"
      >
        Download for Mac
      </a>
      <a
        href={`${githubUrl}#readme`}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github_docs"
        data-cta-surface="website"
      >
        Read the docs on GitHub &rarr;
      </a>
    </div>

    <div class="cli-copy reveal r-d2">
      <code>{installCmd}</code>
      <button
        type="button"
        class="secondary-button copy-button"
        data-copy-text={installCmd}
        data-copy-source="final_cta"
        data-copy-target="cli_install"
        data-copy-surface="website"
      >
        <span data-copy-label>Copy CLI install</span>
      </button>
    </div>

    <div class="cta-muted reveal r-d3">
      <span>Also available as a <a href={`${githubUrl}#install`} class="muted-link" target="_blank" rel="noopener noreferrer">CLI</a></span>
      <span class="sep">&middot;</span>
      <a
        href={githubUrl}
        class="muted-link"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github"
        data-cta-surface="website"
      >
        Star the repo &mdash; it helps others find Shadow
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    margin-bottom: clamp(10rem, 16vw, 16rem);
  }

  .cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-lead {
    max-width: 36rem;
    margin: 1.25rem 0 2.5rem;
    color: var(--text-secondary);
    font-size: 1.15rem;
    line-height: 1.6;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cli-copy {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    width: min(100%, 46rem);
    margin-top: 1.4rem;
    padding: 0.55rem;
    border: 1px solid var(--border);
    border-radius: 0.7rem;
    background: var(--paper);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.12);
  }

  .cli-copy code {
    padding-left: 0.8rem;
    overflow: hidden;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    text-align: left;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .copy-button {
    min-height: 2.65rem;
    padding: 0.65rem 0.95rem;
    white-space: nowrap;
  }

  .cta-muted {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    justify-content: center;
  }

  .muted-link {
    color: var(--text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--border-strong);
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .muted-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .sep {
    color: var(--border-strong);
  }

  @media (max-width: 720px) {
    .cli-copy {
      grid-template-columns: 1fr;
      padding: 0.8rem;
    }

    .cli-copy code {
      width: 100%;
      padding: 0;
      white-space: normal;
      word-break: break-all;
    }

    .copy-button {
      width: 100%;
    }
  }
</style>
