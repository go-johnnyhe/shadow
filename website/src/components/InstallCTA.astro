---
import { githubUrl, installCmd, marketplaceUrl } from '../consts';
---

<section class="cta">
  <div class="section-shell cta-inner reveal">
    <p class="section-kicker">Get started</p>
    <h2 class="section-title">Copy. Paste. You're paired.</h2>
    <p class="cta-lead">
      Install once, start a session, and share the join command. Shadow copies it for you.
    </p>

    <div class="steps reveal r-d1">
      <article class="step">
        <span class="step-n">01</span>
        <h3>Install from the path you want</h3>
        <p>Copy the CLI install or grab the VS Code extension from the Marketplace.</p>
      </article>
      <article class="step">
        <span class="step-n">02</span>
        <h3>Start a session</h3>
        <p>Run `shadow start .` or use the extension, then let Shadow place the join command on your clipboard.</p>
      </article>
      <article class="step">
        <span class="step-n">03</span>
        <h3>Pair in your own tools</h3>
        <p>Your teammate pastes the command into the CLI or extension and starts editing live.</p>
      </article>
    </div>

    <div class="cta-actions reveal r-d2">
      <button
        type="button"
        class="primary-button"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="cli"
        data-cta-surface="website"
        data-copy-text={installCmd}
        data-copy-source="final_cta"
        data-copy-target="cli"
        data-copy-surface="website"
      >
        <span data-copy-label>Copy install command</span>
      </button>

      <a
        href={marketplaceUrl}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="vscode_marketplace"
        data-cta-surface="website"
      >
        Install VS Code extension
      </a>

      <a
        href={githubUrl}
        class="ghost-button"
        target="_blank"
        rel="noopener noreferrer"
        data-cta
        data-cta-source="final_cta"
        data-cta-target="github"
        data-cta-surface="website"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    margin-bottom: var(--gap);
  }

  .cta-inner {
    padding: 1.75rem 2rem;
    border-radius: 1rem;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
  }

  .cta-lead {
    max-width: 36rem;
    margin: 1rem 0 1.5rem;
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .step {
    padding: 1rem 1.2rem;
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: var(--paper);
  }

  .step-n {
    display: inline-block;
    margin-bottom: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    letter-spacing: 0.12em;
  }

  .step h3 {
    font-size: 1rem;
    margin-bottom: 0.35rem;
  }

  .step p {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.9rem;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
  }

  @media (max-width: 860px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .cta-inner {
      padding: 1.25rem 1.4rem;
    }

    .cta-actions {
      flex-direction: column;
    }
  }
</style>
